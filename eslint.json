trol,\r\n  FormField,\r\n  FormItem,\r\n  FormLabel,\r\n  FormMessage,\r\n} from '@/components/ui/form';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport {\r\n  Select,\r\n  SelectContent,\r\n  SelectItem,\r\n  SelectTrigger,\r\n  SelectValue,\r\n} from '@/components/ui/select';\r\nimport { useToast } from '@/hooks/use-toast';\r\nimport { extractAppointmentDetails } from '@/ai/flows/natural-language-appointment-booking';\r\nimport { saveAppointment, updateAppointment, Appointment } from '@/firebase/db';\r\nimport { useFirestore } from '@/firebase';\r\n\r\nconst formSchema = z.object({\r\n  name: z.string().min(2, { message: \"Name must be at least 2 characters.\" }),\r\n  phone: z.string().min(10, { message: \"Please enter a valid phone number.\" }),\r\n  service: z.string({ required_error: \"Please select a service.\" }),\r\n  date: z.string({ required_error: \"Please select a date.\" }).regex(/^\\d{4}-\\d{2}-\\d{2}$/, \"Invalid date format\"),\r\n  time: z.string().regex(/^([01]?[0-9]|2[0-3]):[0-5][0-9]$/, { message: \"Please enter a valid time (HH:MM).\" }),\r\n  notes: z.string().optional(),\r\n});\r\n\r\ninterface AppointmentFormProps {\r\n  initialData?: Appointment;\r\n  onSuccess?: () => void;\r\n}\r\n\r\nexport function AppointmentForm({ initialData, onSuccess }: AppointmentFormProps) {\r\n  const { toast } = useToast();\r\n  const firestore = useFirestore();\r\n  const [isAiLoading, setIsAiLoading] = React.useState(false);\r\n  const [aiRequest, setAiRequest] = React.useState('');\r\n\r\n  const todayStr = format(new Date(), 'yyyy-MM-dd');\r\n\r\n  const form = useForm<z.infer<typeof formSchema>>({\r\n    resolver: zodResolver(formSchema),\r\n    defaultValues: initialData ? {\r\n      name: initialData.name,\r\n      phone: initialData.phone,\r\n      service: initialData.service,\r\n      date: initialData.date,\r\n      time: initialData.time,\r\n      notes: initialData.notes || '',\r\n    } : {\r\n      name: '',\r\n      phone: '',\r\n      service: '',\r\n      date: todayStr,\r\n      time: '10:00',\r\n      notes: '',\r\n    },\r\n  });\r\n\r\n  const handleAiExtraction = async () => {\r\n    if (!aiRequest.trim()) return;\r\n    setIsAiLoading(true);\r\n    try {\r\n      const details = await extractAppointmentDetails({\r\n        request: aiRequest,\r\n        currentDate: todayStr\r\n      });\r\n\r\n      if (details.clientName) form.setValue('name', details.clientName);\r\n      if (details.clientPhone) form.setValue('phone', details.clientPhone);\r\n      if (details.service && details.service !== 'general service') form.setValue('service', details.service);\r\n      if (details.date) form.setValue('date', details.date);\r\n      if (details.time) form.setValue('time', details.time);\r\n      if (details.additionalNotes) form.setValue('notes', details.additionalNotes);\r\n\r\n      toast({\r\n        title: \"Magic Applied!\",\r\n        description: \"Form populated successfully.\",\r\n      });\r\n      setAiRequest('');\r\n    } catch (error) {\r\n      toast({\r\n        variant: \"destructive\",\r\n        title: \"AI Failed\",\r\n        description: \"Could not process request.\",\r\n      });\r\n    } finally {\r\n      setIsAiLoading(false);\r\n    }\r\n  };\r\n\r\n  function onSubmit(values: z.infer<typeof formSchema>) {\r\n    if (!firestore) return;\r\n\r\n    if (initialData?.id) {\r\n      updateAppointment(firestore, initialData.id, values as any);\r\n    } else {\r\n      saveAppointment(firestore, values as any);\r\n    }\r\n\r\n    toast({\r\n      title: initialData ? \"Updating...\" : \"Booking...\",\r\n      description: `Request for ${values.name} is being processed.`,\r\n    });\r\n\r\n    if (onSuccess) onSuccess();\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      {!initialData && (\r\n        <div className=\"p-3 rounded-lg bg-accent/5 border border-accent/10 space-y-2\">\r\n          <div className=\"flex items-center gap-2 text-accent font-semibold text-[10px] uppercase tracking-wider\">\r\n            <Sparkles className=\"w-3 h-3\" />\r\n            <span>AI Quick Fill</span>\r\n          </div>\r\n          <div className=\"flex gap-2\">\r\n            <Input\r\n              placeholder=\"e.g., 'Jane - hair cut tomorrow at 4pm'\"\r\n              value={aiRequest}\r\n              onChange={(e) => setAiRequest(e.target.value)}\r\n              onKeyDown={(e) => e.key === 'Enter' && handleAiExtraction()}\r\n              className=\"h-8 text-xs\"\r\n            />\r\n            <Button\r\n              type=\"button\"\r\n              variant=\"default\"\r\n              size=\"sm\"\r\n              onClick={handleAiExtraction}\r\n              disabled={isAiLoading || !aiRequest.trim()}\r\n              className=\"h-8 px-3 text-xs bg-accent hover:bg-accent/90\"\r\n            >\r\n              {isAiLoading ? <Loader2 className=\"w-3 h-3 animate-spin\" /> : \"Fill\"}\r\n            </Button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      <Form {...form}>\r\n        <form onSubmit={form.handleSubmit(onSubmit)} className=\"space-y-4\">\r\n          <div className=\"grid grid-cols-2 gap-4\">\r\n            <FormField\r\n              control={form.control}\r\n              name=\"name\"\r\n              render={({ field }) => (\r\n                <FormItem>\r\n                  <FormLabel>Client Name</FormLabel>\r\n                  <FormControl>\r\n                    <Input placeholder=\"John Doe\" {...field} />\r\n                  </FormControl>\r\n                  <FormMessage />\r\n                </FormItem>\r\n              )}\r\n            />\r\n            <FormField\r\n              control={form.control}\r\n              name=\"phone\"\r\n              render={({ field }) => (\r\n                <FormItem>\r\n                  <FormLabel>Phone</FormLabel>\r\n                  <FormControl>\r\n                    <Input placeholder=\"(555) 000-0000\" {...field} />\r\n                  </FormControl>\r\n                  <FormMessage />\r\n                </FormItem>\r\n              )}\r\n            />\r\n          </div>\r\n\r\n          <FormField\r\n            control={form.control}\r\n            name=\"service\"\r\n            render={({ field }) => (\r\n              <FormItem>\r\n                <FormLabel>Service</FormLabel>\r\n                <Select onValueChange={field.onChange} defaultValue={field.value} value={field.value}>\r\n                  <FormControl>\r\n                    <SelectTrigger>\r\n                      <SelectValue placeholder=\"Select a service\" />\r\n                    </SelectTrigger>\r\n                  </FormControl>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"haircut\">Haircut & Styling</SelectItem>\r\n                    <SelectItem value=\"coloring\">Coloring & Highlights</SelectItem>\r\n                    <SelectItem value=\"manicure\">Manicure & Pedicure</SelectItem>\r\n                    <SelectItem value=\"facial\">Facial Treatment</SelectItem>\r\n                    <SelectItem value=\"waxing\">Waxing</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n                <FormMessage />\r\n              </FormItem>\r\n            )}\r\n          />\r\n\r\n          <div className=\"grid grid-cols-2 gap-4\">\r\n            <FormField\r\n              control={form.control}\r\n              name=\"date\"\r\n              render={({ field }) => (\r\n                <FormItem>\r\n                  <FormLabel>Date</FormLabel>\r\n                  <FormControl>\r\n                    <Input\r\n                      type=\"date\"\r\n                      min={todayStr}\r\n                      className=\"h-10\"\r\n                      {...field}\r\n                    />\r\n                  </FormControl>\r\n                  <FormMessage />\r\n                </FormItem>\r\n              )}\r\n            />\r\n            <FormField\r\n              control={form.control}\r\n              name=\"time\"\r\n              render={({ field }) => (\r\n                <FormItem>\r\n                  <FormLabel>Time</FormLabel>\r\n                  <FormControl>\r\n                    <Input type=\"time\" {...field} />\r\n                  </FormControl>\r\n                  <FormMessage />\r\n                </FormItem>\r\n              )}\r\n            />\r\n          </div>\r\n\r\n          <FormField\r\n            control={form.control}\r\n            name=\"notes\"\r\n            render={({ field }) => (\r\n              <FormItem>\r\n                <FormLabel>Notes (Optional)</FormLabel>\r\n                <FormControl>\r\n                  <Textarea\r\n                    placeholder=\"Extra details...\"\r\n                    className=\"resize-none min-h-[60px]\"\r\n                    {...field}\r\n                  />\r\n                </FormControl>\r\n                <FormMessage />\r\n              </FormItem>\r\n            )}\r\n          />\r\n\r\n          <Button type=\"submit\" className=\"w-full font-bold h-11\" disabled={form.formState.isSubmitting}>\r\n            {initialData ? 'Update Appointment' : 'Confirm Booking'}\r\n          </Button>\r\n        </form>\r\n      </Form>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\scratch\\mens-salon\\src\\components\\dashboard\\appointment-list.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\scratch\\mens-salon\\src\\components\\dashboard\\stats-cards.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":36,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":36,"endColumn":21}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport * as React from 'react';\r\nimport { Users, CalendarCheck, Sparkles, TrendingUp } from 'lucide-react';\r\nimport { format } from 'date-fns';\r\n\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Appointment } from '@/firebase/db';\r\nimport { adminDailyAppointmentSummary } from '@/ai/flows/admin-daily-appointment-summary';\r\n\r\ninterface StatsCardsProps {\r\n  appointments: Appointment[];\r\n}\r\n\r\nexport function StatsCards({ appointments }: StatsCardsProps) {\r\n  const [summary, setSummary] = React.useState<string>('Generating daily overview...');\r\n  const [isSummarizing, setIsSummarizing] = React.useState(false);\r\n\r\n  React.useEffect(() => {\r\n    const fetchSummary = async () => {\r\n      if (appointments.length === 0) {\r\n        setSummary(\"No bookings today yet. Get started by adding one manually!\");\r\n        return;\r\n      }\r\n\r\n      setIsSummarizing(true);\r\n      try {\r\n        const todayStr = format(new Date(), 'yyyy-MM-dd');\r\n        const todayAppointments = appointments.filter(a => a.date === todayStr);\r\n\r\n        const result = await adminDailyAppointmentSummary({\r\n          date: todayStr,\r\n          appointments: todayAppointments\r\n        });\r\n        setSummary(result.summary);\r\n      } catch (error) {\r\n        setSummary(\"Welcome back. Check your latest bookings below.\");\r\n      } finally {\r\n        setIsSummarizing(false);\r\n      }\r\n    };\r\n\r\n    fetchSummary();\r\n  }, [appointments]);\r\n\r\n  const stats = [\r\n    {\r\n      title: \"Total Bookings\",\r\n      value: appointments.length.toString(),\r\n      icon: CalendarCheck,\r\n      color: \"text-primary\",\r\n      bg: \"bg-primary/10\",\r\n    },\r\n    {\r\n      title: \"Active Clients\",\r\n      value: new Set(appointments.map(a => a.phone)).size.toString(),\r\n      icon: Users,\r\n      color: \"text-accent\",\r\n      bg: \"bg-accent/10\",\r\n    },\r\n    {\r\n      title: \"Completion Rate\",\r\n      value: appointments.length > 0\r\n        ? `${Math.round((appointments.filter(a => a.status === 'completed').length / appointments.length) * 100)}%`\r\n        : \"0%\",\r\n      icon: TrendingUp,\r\n      color: \"text-green-600\",\r\n      bg: \"bg-green-100\",\r\n    }\r\n  ];\r\n\r\n  return (\r\n    <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\r\n      {stats.map((stat, i) => (\r\n        <Card key={i} className=\"border-none shadow-sm overflow-hidden relative\">\r\n          <CardHeader className=\"flex flex-row items-center justify-between pb-2 space-y-0\">\r\n            <CardTitle className=\"text-sm font-medium text-muted-foreground\">{stat.title}</CardTitle>\r\n            <div className={`p-2 rounded-lg ${stat.bg} ${stat.color}`}>\r\n              <stat.icon className=\"w-4 h-4\" />\r\n            </div>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">{stat.value}</div>\r\n          </CardContent>\r\n        </Card>\r\n      ))}\r\n\r\n      <Card className=\"md:col-span-1 bg-primary text-primary-foreground border-none shadow-md\">\r\n        <CardHeader className=\"flex flex-row items-center justify-between pb-2 space-y-0\">\r\n          <CardTitle className=\"text-sm font-medium opacity-80 flex items-center gap-2\">\r\n            <Sparkles className=\"w-3.5 h-3.5\" />\r\n            AI Daily Summary\r\n          </CardTitle>\r\n        </CardHeader>\r\n        <CardContent>\r\n          <p className={`text-xs leading-relaxed ${isSummarizing ? 'animate-pulse' : ''}`}>\r\n            {summary}\r\n          </p>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\sc