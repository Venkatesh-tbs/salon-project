iv\n            className=\"gallery-item\"\n            style={{\n              backgroundImage:\n                \"url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=800&auto=format&fit=crop')\",\n            }}\n          >\n            <div className=\"gallery-overlay\">Beard Sculpting</div>\n          </div>\n          <div\n            className=\"gallery-item\"\n            style={{\n              backgroundImage:\n                \"url('https://images.unsplash.com/photo-1582095133179-bfd08e2fc6b3?q=80&w=800&auto=format&fit=crop')\",\n            }}\n          >\n            <div className=\"gallery-overlay\">Premium Styling</div>\n          </div>\n          <div\n            className=\"gallery-item\"\n            style={{\n              backgroundImage:\n                \"url('/man-barbershop-salon-doing-haircut-beard-trim.jpg')\",\n            }}\n          >\n            <div className=\"gallery-overlay\">Relaxing Wash</div>\n          </div>\n          <div\n            className=\"gallery-item\"\n            style={{\n              backgroundImage:\n                \"url('/hands-unrecognizable-hairdresser-giving-male-customer-blowdry-with-hairdryer-comb.jpg')\",\n            }}\n          >\n            <div className=\"gallery-overlay\">Quality Tools</div>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"booking\" className=\"section\">\n        <h2 className=\"section-title\">Book Appointment</h2>\n        <div className=\"booking-container\">\n          <BookingForm />\n        </div>\n      </section>\n\n      <footer id=\"contact\">\n        <div className=\"footer-content\">\n          <div className=\"footer-info\">\n            <h3>LUXE Men's Salon</h3>\n            <p>123 Prestige Ave, City, Country</p>\n            <p>Contact: +1 (555) 123-4567</p>\n          </div>\n          <div className=\"footer-hours\">\n            <h3>Hours</h3>\n            <p>Mon - Fri: 9:00 AM - 8:00 PM</p>\n            <p>Sat: 10:00 AM - 6:00 PM</p>\n            <p>Sun: Closed</p>\n          </div>\n        </div>\n        <div className=\"footer-bottom\">\n          <p>\n            &copy; 2026 LUXE Premium Salon. Built for Modern Men. All Rights Reserved.\n          </p>\n        </div>\n      </footer>\n    </>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\scratch\\mens-salon\\src\\components\\BookingForm.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":48,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":48,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1456,1459],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1456,1459],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from \"react\";\nimport { collection, addDoc, serverTimestamp } from \"firebase/firestore\";\nimport { db } from \"@/lib/firebase\";\n\nexport default function BookingForm() {\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [errorText, setErrorText] = useState(\"\");\n\n  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {\n    e.preventDefault();\n    setLoading(true);\n    setSuccess(false);\n    setErrorText(\"\");\n\n    const formData = new FormData(e.currentTarget);\n    const name = formData.get(\"name\") as string;\n    const phone = formData.get(\"phone\") as string;\n    const service = formData.get(\"service\") as string;\n    const date = formData.get(\"date\") as string;\n    const time = formData.get(\"time\") as string;\n\n    try {\n      try {\n        await addDoc(collection(db, \"appointments\"), {\n          name,\n          phone,\n          service,\n          date,\n          time,\n          timestamp: serverTimestamp(),\n        });\n      } catch (fbError) {\n        console.warn(\"Firebase not properly configured. Simulating success fallback.\", fbError);\n        // Fallback simulation\n        await new Promise((resolve) => setTimeout(resolve, 1000));\n      }\n\n      setSuccess(true);\n      if (e.target instanceof HTMLFormElement) {\n        e.target.reset();\n      }\n      setTimeout(() => {\n        setSuccess(false);\n      }, 4000);\n    } catch (err: any) {\n      console.error(\"Booking error:\", err);\n      setErrorText(\"Error! Try Again.\");\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <form className=\"glass-form visible\" onSubmit={handleSubmit}>\n      <div className=\"form-row\">\n        <div className=\"form-group\">\n          <label htmlFor=\"name\">Name</label>\n          <input type=\"text\" id=\"name\" name=\"name\" required placeholder=\"John Doe\" />\n        </div>\n        <div className=\"form-group\">\n          <label htmlFor=\"phone\">Phone Number</label>\n          <input\n            type=\"tel\"\n            id=\"phone\"\n            name=\"phone\"\n            required\n            placeholder=\"(555) 000-0000\"\n          />\n        </div>\n      </div>\n      <div className=\"form-group\">\n        <label htmlFor=\"service\">Service</label>\n        <select id=\"service\" name=\"service\" required defaultValue=\"\">\n          <option value=\"\" disabled>\n            Select a service\n          </option>\n          <option value=\"haircut\">Haircut</option>\n          <option value=\"beard\">Beard Trim</option>\n          <option value=\"styling\">Hair Styling</option>\n          <option value=\"facial\">Facial</option>\n        </select>\n      </div>\n      <div className=\"form-row\">\n        <div className=\"form-group\">\n          <label htmlFor=\"date\">Date</label>\n          <input type=\"date\" id=\"date\" name=\"date\" required />\n        </div>\n        <div className=\"form-group\">\n          <label htmlFor=\"time\">Time</label>\n          <input type=\"time\" id=\"time\" name=\"time\" required />\n        </div>\n      </div>\n      \n      <button\n        type=\"submit\"\n        className=\"btn-primary block\"\n        disabled={loading}\n        style={success ? { backgroundColor: \"#d4af37\", color: \"#000\", boxShadow: \"0 0 20px rgba(212, 175, 55, 0.6)\" } : {}}\n      >\n        {loading ? \"Booking...\" : success ? \"Booking Confirmed!\" : errorText || \"Confirm Booking\"}\n      </button>\n\n      {success && (\n        <div\n          id=\"booking-success\"\n          className=\"success-message\"\n          style={{\n            textAlign: \"center\",\n            marginTop: \"15px\",\n            color: \"#4ade80\",\n            fontWeight: 500,\n          }}\n        >\n          Appointment booked successfully!\n        </div>\n      )}\n    </form>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\scratch\\mens-salon\\src\\components\\HeroCanvas.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The ref value 'mountRef.current' will likely have changed by the time this effect cleanup function runs. If this ref points to a node rendered by React, copy 'mountRef.current' to a variable inside the effect, and use that variable in the cleanup function.","line":191,"column":18,"nodeType":"Identifier","endLine":191,"endColumn":25}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useEffect, useRef } from \"react\";\nimport * as THREE from \"three\";\n\nexport default function HeroCanvas() {\n  const mountRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (!mountRef.current) return;\n\n    const w = window.innerWidth;\n    const h = window.innerHeight;\n\n    // Scene setup\n    const scene = new THREE.Scene();\n\n    // Camera setup\n    const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 1000);\n    camera.position.z = 10;\n    camera.position.x = 2.5;\n\n    // Renderer setup\n    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });\n    renderer.setSize(w, h);\n    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n    \n    // Attach canvas to mountref\n    const canvas = renderer.domElement;\n    mountRef.current.appendChild(canvas);\n    canvas.style.position = \"absolute\";\n    canvas.style.top = \"0\";\n    canvas.style.left = \"0\";\n    canvas.style.width = \"100%\";\n    canvas.style.height = \"100%\";\n    canvas.style.zIndex = \"-1\";\n    canvas.style.pointerEvents = \"none\";\n\n    // Create striped texture procedurally\n    const createStripedTexture = () => {\n      const ctxCanvas = document.createElement(\"canvas\");\n      ctxCanvas.width = 512;\n      ctxCanvas.height = 512;\n      const ctx = ctxCanvas.getContext(\"2d\");\n      if (!ctx) return new THREE.Texture();\n\n      ctx.fillStyle = \"#ffffff\";\n      ctx.fillRect(0, 0, 512, 512);\n\n      const stripeWidth = 60;\n      ctx.save();\n      ctx.translate(256, 256);\n      ctx.rotate(Math.PI / 4);\n      ctx.translate(-500, -500);\n\n      for (let i = 0; i < 20; i++) {\n        const x = i * stripeWidth * 3;\n        ctx.fillStyle = \"#d4af37\";\n        ctx.fillRect(x, 0, stripeWidth, 1000);\n        ctx.fillStyle = \"#1a1a1a\";\n        ctx.fillRect(x + stripeWidth, 0, stripeWidth, 1000);\n        ctx.fillStyle = \"#e8e8e8\";\n        ctx.fillRect(x + stripeWidth * 2, 0, stripeWidth, 1000);\n      }\n      ctx.restore();\n\n      const texture = new THREE.CanvasTexture(ctxCanvas);\n      texture.wrapS = THREE.RepeatWrapping;\n      texture.wrapT = THREE.RepeatWrapping;\n      texture.repeat.set(2, 4);\n      return texture;\n    };\n\n    const texture = createStripedTexture();\n\n    // Material\n    const material = new THREE.MeshStandardMaterial({\n      map: texture,\n      roughness: 0.2,\n      metalness: 0.5,\n    });\n\n    // Geometry\n    const geometry = new THREE.CylinderGeometry(0.8, 0.8, 6.5, 32);\n    const barberPole = new THREE.Mesh(geometry, material);\n    barberPole.rotation.z = 0.15;\n    scene.add(barberPole);\n\n    // Caps\n    const capGeo = new THREE.SphereGeometry(\n      0.85,\n      32,\n      16,\n      0,\n      Math.PI * 2,\n      0,\n      Math.PI / 2\n    );\n    const capMat = new THREE.MeshStandardMaterial({\n      color: 0xd4af37,\n      roughness: 0.1,\n      metalness: 1.0,\n    });\n\n    const topCap = new THREE.Mesh(capGeo, capMat);\n    topCap.position.y = 3.25;\n    barberPole.add(topCap);\n\n    const bottomCap = new THREE.Mesh(capGeo, capMat);\n    bottomCap.position.y = -3.25;\n    bottomCap.rotation.x = Math.PI;\n    barberPole.add(bottomCap);\n\n    // Light\n    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n    scene.add(ambientLight);\n\n    const directionalLight1 = new THREE.DirectionalLight(0xffffff, 1.5);\n    directionalLight1.position.set(5, 5, 5);\n    scene.add(directionalLight1);\n\n    const directionalLight2 = new THREE.DirectionalLight(0xffffff, 0.8);\n    directionalLight2.position.set(-5, 5, 5);\n    scene.add(directionalLight2);\n\n    const goldBackLight = new THREE.DirectionalLight(0xd4af37, 1.5);\n    goldBackLight.position.set(0, -5, -5);\n    scene.add(goldBackLight);\n\n    let mouseX = 0;\n    let mouseY = 0;\n    let targetRotationY = 0;\n\n    const handleMouseMove = (event: MouseEvent) => {\n      mouseX = (event.clientX / window.innerWidth) * 2 - 1;\n      mouseY = -(event.clientY / window.innerHeight) * 2 + 1;\n    };\n    window.addEventListener(\"mousemove\", handleMouseMove);\n\n    const clock = new THREE.Clock();\n    let animationFrameId: number;\n\n    const animate = () => {\n      animationFrameId = requestAnimationFrame(animate);\n      const delta = clock.getDelta();\n\n      if (texture.offset) {\n          texture.offset.y -= 0.6 * delta;\n      }\n\n      targetRotationY = mouseX * 0.3;\n      const targetRotationX = mouseY * 0.15;\n\n      barberPole.rotation.x += (targetRotationX - barberPole.rotation.x) * 3 * delta;\n      barberPole.rotation.y += (targetRotationY - barberPole.rotation.y) * 3 * delta;\n\n      const time = clock.getElapsedTime();\n      barberPole.position.y = Math.sin(time * 1.5) * 0.15;\n\n      renderer.render(scene, camera);\n    };\n    animate();\n\n    const handleResize = () => {\n      camera.aspect = window.innerWidth / window.innerHeight;\n      camera.updateProjectionMatrix();\n      renderer.setSize(window.innerWidth, window.innerHeight);\n\n      if (window.innerWidth < 1024) {\n        camera.position.x = 1.5;\n        camera.position.z = 10;\n        barberPole.position.y = 0;\n      }\n      if (window.innerWidth < 768) {\n        camera.position.x = 0;\n        camera.position.z = 13;\n        barberPole.position.y = 1.5;\n      } else {\n        camera.position.z = 10;\n        barberPole.position.y = 0;\n      }\n    };\n    window.addEventListener(\"resize\", handleResize);\n    handleResize();\n\n    return () => {\n      window.removeEventListener(\"mousemove\", handleMouseMove);\n      window.removeEventListener(\"resize\", handleResize);\n      cancelAnimationFrame(animationFrameId);\n      if (mountRef.current && canvas.parentNode) {\n        mountRef.current.removeChild(canvas);\n      }\n      geometry.dispose();\n      material.dispose();\n      capGeo.dispose();\n      capMat.dispose();\n      renderer.dispose();\n    };\n  }, []);\n\n  return <div ref={mountRef} />;\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PC\\.gemini\\antigravity\\scratch\\mens-salon\\src\\com